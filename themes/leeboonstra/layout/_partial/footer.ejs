<script>
// Detect and dynamically initialize Mermaid diagrams in blog posts
function initMermaidDiagrams() {
  const candidateBlocks = document.querySelectorAll(
    'figure.highlight, pre.language-mermaid, code.language-mermaid, pre.mermaid, code.mermaid, pre code'
  );
  
  const targets = [];
  const mermaidRegex = /^\s*(graph\s+|flowchart\s+|sequenceDiagram|classDiagram|stateDiagram|erDiagram|gantt|pie|journey|gitGraph|requirementDiagram|mindmap|timeline|c4Context)/;

  candidateBlocks.forEach(function(block) {
    let container = block;
    if (block.tagName === 'CODE') {
      if (block.parentNode.tagName === 'PRE') {
        container = block.parentNode;
      }
    }
    
    if (targets.indexOf(container) === -1) {
      let rawContent = '';
      const lineElems = container.querySelectorAll('td.code pre .line, pre code .line, .line');
      if (lineElems.length > 0) {
        const lines = Array.from(lineElems).map(function(el) { return el.textContent; });
        rawContent = lines.join('\n');
      } else {
        const codeElem = container.querySelector('td.code pre, pre code, code');
        rawContent = codeElem ? codeElem.textContent : container.textContent;
      }
      
      const codeElem = container.querySelector('td.code pre, pre code, code');
      const hasMermaidClass = container.className.includes('mermaid') || 
                               (codeElem && codeElem.className.includes('mermaid'));
      
      if (hasMermaidClass || mermaidRegex.test(rawContent)) {
        targets.push({
          container: container,
          content: rawContent
        });
      }
    }
  });
  
  if (targets.length > 0) {
    targets.forEach(function(item) {
      const mermaidDiv = document.createElement('div');
      mermaidDiv.className = 'mermaid';
      mermaidDiv.style.display = 'flex';
      mermaidDiv.style.justifyContent = 'center';
      mermaidDiv.style.margin = '2rem 0';
      mermaidDiv.textContent = item.content.trim();
      
      item.container.parentNode.replaceChild(mermaidDiv, item.container);
    });
    
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js';
    script.onload = function() {
      if (typeof mermaid !== 'undefined') {
        mermaid.initialize({
          startOnLoad: true,
          theme: 'neutral',
          securityLevel: 'loose'
        });
      }
    };
    document.body.appendChild(script);
  }
}
</script>
<script>
// Add language classes to hexo-prism code blocks and trigger highlighting
function initPrismHighlighting() {
  // Find all figure.highlight elements
  const codeBlocks = document.querySelectorAll('figure.highlight');
  
  codeBlocks.forEach(function(figure) {
    const pre = figure.querySelector('pre');
    if (pre) {
      // Extract language from figure class (e.g., "highlight plaintext" -> "plaintext")
      const className = figure.className;
      const languageMatch = className.match(/highlight\s+(\w+)/);
      const language = languageMatch ? languageMatch[1] : 'plaintext';
      
      // Add language class to pre element (preserve existing classes)
      if (!pre.className.includes('language-' + language)) {
        pre.className = pre.className + ' language-' + language;
      }
      
      // Also add it to the code element if it exists
      const code = pre.querySelector('code');
      if (code) {
        if (!code.className.includes('language-' + language)) {
          code.className = code.className + ' language-' + language;
        }
      }
    }
  });
  
  // Trigger Prism highlighting after adding classes
  if (typeof Prism !== 'undefined') {
    Prism.highlightAll();
  }
}

// Wait for DOM to be ready
document.addEventListener('DOMContentLoaded', function() {
  initMermaidDiagrams();
  // Small delay to ensure all scripts are loaded
  setTimeout(initPrismHighlighting, 50);
});
</script>

<script>
// Register PWA Service Worker with safe auto-refresh on active takeover
if ('serviceWorker' in navigator) {
  window.addEventListener('load', function() {
    navigator.serviceWorker.register('/serviceworker.js').then(function(registration) {
      console.log('PWA Service Worker registered successfully:', registration);
      
      // Force update check on register to accelerate discovery
      registration.update();
      
      // If there is an active waiting service worker, prompt immediate installation
      if (registration.waiting) {
        registration.waiting.postMessage({ type: 'SKIP_WAITING' });
      }
    }).catch(function(err) {
      console.warn('PWA Service Worker registration failed:', err);
    });
  });

  // Track service worker controller changes to perform a clean tab auto-refresh
  let refreshing = false;
  navigator.serviceWorker.addEventListener('controllerchange', function() {
    if (!refreshing) {
      refreshing = true;
      console.log('New PWA Service Worker took control. Refreshing viewport...');
      window.location.reload();
    }
  });
}
</script>


