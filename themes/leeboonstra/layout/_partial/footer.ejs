<script>
// Detect and dynamically initialize Mermaid diagrams in blog posts
function initMermaidDiagrams() {
  const mermaidBlocks = document.querySelectorAll(
    'figure.highlight.mermaid, figure.highlight.language-mermaid, pre.language-mermaid, code.language-mermaid, pre.mermaid, code.mermaid'
  );
  
  if (mermaidBlocks.length > 0) {
    const targets = [];
    
    mermaidBlocks.forEach(function(block) {
      let container = block;
      if (block.tagName === 'CODE') {
        if (block.parentNode.tagName === 'PRE') {
          container = block.parentNode;
        }
      }
      if (targets.indexOf(container) === -1) {
        targets.push(container);
      }
    });
    
    targets.forEach(function(container) {
      const codeElem = container.querySelector('td.code pre, pre code, code');
      const rawContent = codeElem ? codeElem.textContent : container.textContent;
      
      const mermaidDiv = document.createElement('div');
      mermaidDiv.className = 'mermaid';
      mermaidDiv.style.display = 'flex';
      mermaidDiv.style.justifyContent = 'center';
      mermaidDiv.style.margin = '2rem 0';
      mermaidDiv.textContent = rawContent.trim();
      
      container.parentNode.replaceChild(mermaidDiv, container);
    });
    
    // Dynamically load Mermaid JS from public CDN
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js';
    script.onload = function() {
      if (typeof mermaid !== 'undefined') {
        mermaid.initialize({
          startOnLoad: true,
          theme: 'neutral',
          securityLevel: 'loose'
        });
      }
    };
    document.body.appendChild(script);
  }
}
</script>
<script>
// Add language classes to hexo-prism code blocks and trigger highlighting
function initPrismHighlighting() {
  // Find all figure.highlight elements
  const codeBlocks = document.querySelectorAll('figure.highlight');
  
  codeBlocks.forEach(function(figure) {
    const pre = figure.querySelector('pre');
    if (pre) {
      // Extract language from figure class (e.g., "highlight plaintext" -> "plaintext")
      const className = figure.className;
      const languageMatch = className.match(/highlight\s+(\w+)/);
      const language = languageMatch ? languageMatch[1] : 'plaintext';
      
      // Add language class to pre element (preserve existing classes)
      if (!pre.className.includes('language-' + language)) {
        pre.className = pre.className + ' language-' + language;
      }
      
      // Also add it to the code element if it exists
      const code = pre.querySelector('code');
      if (code) {
        if (!code.className.includes('language-' + language)) {
          code.className = code.className + ' language-' + language;
        }
      }
    }
  });
  
  // Trigger Prism highlighting after adding classes
  if (typeof Prism !== 'undefined') {
    Prism.highlightAll();
  }
}

// Wait for DOM to be ready
document.addEventListener('DOMContentLoaded', function() {
  initMermaidDiagrams();
  // Small delay to ensure all scripts are loaded
  setTimeout(initPrismHighlighting, 50);
});
</script>


