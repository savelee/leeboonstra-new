      "image": "<%- ogImage %>",
      "datePublished": "<%= page.date.toISOString() %>",
      "dateCreated": "<%= page.date.toISOString() %>",
      "dateModified": "<%= (page.updated || page.date).toISOString() %>",
      "author": {
        "@type": "Person",
        "name": "Lee Boonstra",
        "@id": "https://www.leeboonstra.dev/#person"
      },
      "publisher": {
        "@type": "Person",
        "name": "Lee Boonstra",
        "@id": "https://www.leeboonstra.dev/#person"
      },
      "keywords": "<%= page.tags.map(t => t.name).join(', ') %>",
      "genre": "technology",
      "about": [
        <%- page.tags.map(t => `{"@type": "Thing", "name": "${t.name.replace(/"/g, '\\"')}"}`).join(',\n        ') %>
      ],
      "articleBody": "<%= page.content.replace(/<\/?[^>]+(>|$)/g, "").replace(/\s+/g, " ").replace(/"/g, '\\"').trim() %>",
      <% if (isTech) { %>
      "dependencies": "<%= dependencies.replace(/"/g, '\\"') %>",
      "proficiencyLevel": "<%= proficiencyLevel.replace(/"/g, '\\"') %>",
      <% } %>
      "speakable": <%- JSON.stringify(speakableSpec, null, 2) %>
    }
  </script>
  <% } %>

