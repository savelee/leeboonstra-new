  <% if (is_post()) { %>
  <%
    // 1. Differentiate technical deep-dives vs standard posts
    var techTerms = ['dialogflow', 'gemini', 'machine learning', 'ai', 'generative ai', 'vertex ai', 'pytorch', 'mlops', 'agent', 'llm', 'convai', 'voice ai'];
    var categories = page.categories ? page.categories.map(c => c.name.toLowerCase()) : [];
    var tags = page.tags ? page.tags.map(t => t.name.toLowerCase()) : [];
    
    var isTech = page.layout === 'tech' || 
                 page.type === 'TechArticle' || 
                 page.dependencies || 
                 page.proficiencyLevel ||
                 categories.some(c => techTerms.includes(c)) ||
                 tags.some(t => techTerms.includes(t));

    var schemaType = isTech ? 'TechArticle' : 'BlogPosting';

    // 2. Resolve target learning carousel properties with smart fallbacks
    var dependencies = page.dependencies || '';
    if (!dependencies && isTech) {
      var matchTags = page.tags ? page.tags.map(t => t.name).filter(t => ['Dialogflow', 'Gemini', 'Vertex AI', 'PyTorch', 'Node.js', 'Python'].includes(t)) : [];
      dependencies = matchTags.length > 0 ? matchTags.join(', ') : 'Basic technical concepts';
    }
    var proficiencyLevel = page.proficiencyLevel || (isTech ? 'Intermediate' : '');

    // 3. Resolve dynamic Speakable selectors matching actual post DOM structure
    var speakableSelectors = [];
    if (page.speakable) {
      if (Array.isArray(page.speakable)) {
        speakableSelectors = page.speakable;
      } else if (typeof page.speakable === 'string') {
        speakableSelectors.push(page.speakable);
      }
    } else if (page.content) {
      if (page.content.indexOf('class="speakable-summary"') !== -1 || page.content.indexOf('id="speakable-summary"') !== -1) {
        speakableSelectors.push('.speakable-summary');
      }
      if (page.content.indexOf('class="speakable-takeaways"') !== -1 || page.content.indexOf('id="speakable-takeaways"') !== -1) {
        speakableSelectors.push('.speakable-takeaways');
      }
    }

    var speakableSpec = null;
    if (speakableSelectors.length > 0) {
      speakableSpec = {
        "@type": "SpeakableSpecification",
        "cssSelector": speakableSelectors
      };
    } else {
      speakableSpec = {
        "@type": "SpeakableSpecification",
        "xpath": [
          "/html/head/title",
          "/html/head/meta[@name='description']/@content"
        ]
      };
    }
  %>
