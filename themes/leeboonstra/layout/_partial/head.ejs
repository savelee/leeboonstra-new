  <!-- Instant E-Reader / Reader Mode State Application -->
  <script>
    (function() {
      var params = new URLSearchParams(window.location.search);
      var isReaderMode = params.has('reader') || params.has('ereader') || localStorage.getItem('reader-mode') === 'true';
      
      if (params.get('reader') === '0' || params.get('ereader') === '0') {
        isReaderMode = false;
      }
      
      if (isReaderMode) {
        document.documentElement.classList.add('force-ereader');
      }
    })();
  </script>

  <% if (config.google_analytics) { %>
  <!-- Google tag (gtag.js) - Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= config.google_analytics %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    // Programmatically disable tracking in local development environments to prevent data pollution
    if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1' || window.location.hostname.endsWith('.local')) {
      window['ga-disable-<%= config.google_analytics %>'] = true;
      console.log('Google Analytics is programmatically disabled on localhost.');
    }

    gtag('config', '<%= config.google_analytics %>');
  </script>
  <% } %>
