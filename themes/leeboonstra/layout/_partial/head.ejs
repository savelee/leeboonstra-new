  <%
  var title = page.title;
  if (is_archive()){
    title = 'Archive';
    if (is_month()){
      title += ': ' + page.year + '/' + page.month;
    } else if (is_year()){
      title += ': ' + page.year;
    }
  } else if (is_category()){
    title = 'Conversational AI: ' + page.category;
  } else if (is_tag()){
    title = page.tag;
  }

  // keywords.
  var keyWords = config.keywords ? config.keywords : config.title;

  // Resolve social share parameters (Open Graph & Twitter Cards) safely
  var ogType = is_post() ? 'article' : 'website';
  var ogUrl = page.permalink || '';
  if (!ogUrl) {
    var pathStr = page.path || '';
    var rootStr = config.root || '/';
    if (pathStr.startsWith('/')) {
      pathStr = pathStr.substring(1);
    }
    if (!rootStr.endsWith('/')) {
      rootStr += '/';
    }
    ogUrl = config.url + rootStr + pathStr;
  }
  if (ogUrl && !ogUrl.startsWith('http')) {
    ogUrl = config.url + (ogUrl.startsWith('/') ? '' : '/') + ogUrl;
  }
  var ogTitle = (title ? title : (config.title ? config.title : '')).trim();
  
  var ogDescriptionRaw = page.description || page.excerpt || config.description || '';
  var ogDescription = strip_html(ogDescriptionRaw).replace(/\s+/g, ' ').trim();
  if (ogDescription.length > 200) {
    ogDescription = ogDescription.substring(0, 197) + '...';
  }
  
  var ogImage = config.url + '/images/screen.png';
  if (page.featured) {
    ogImage = config.url + '/images/large_' + page.featured + '.webp';
  }
