<div class="container about">
  <div class="row justify-content-md-center">
    <div class="col-8 blogcontent">

      <div class="article-meta-utility">
        <%- partial('_partial/reader_toggle') %>
      </div>
      <h1><%- page.title %></h1>

      <%- page.content %>

      <!-- Dynamic category posts loop for books and publication reviews -->
      <% site.categories.findOne({name: 'Writing'}).posts.sort('date', -1).forEach(function(post) { %>
      <div class="portfolio-card">
        <h2 class="mb-2"><a href="<%- url_for(post.path) %>" style="color: #0f172a; text-decoration: none;"><%- post.title -%></a></h2>

        <%- post.excerpt %>
        <div class="mt-3">
          <a href="<%- url_for(post.path) %>" class="btn btn-sm btn-outline-primary">Continue Reading</a>
        </div>
      </div>
      
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "NewsArticle",
          "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": "<%- post.permalink %>"
          },
          "headline": "<%- post.title %>",
          "image": [
            "<%- post.thumbnail %>"
           ],
           "datePublished": "<%- post.date.toISOString() %>",
           "dateModified": "<%- post.date.toISOString() %>",
          "author": {
            "@type": "Person",
            "name": "Lee Boonstra",
            "@id": "https://www.leeboonstra.dev/#person"
          },
          "publisher": {
            "@type": "Person",
            "name": "Lee Boonstra",
            "@id": "https://www.leeboonstra.dev/#person"
          }
        }
      </script>
      <% }) %>  

    </div>
    
    <div class="col-4 photocol">
      <div class="card shadow sidebar">
        <div class="card-body">
          <h3 class="card-title">Photo's</h3>
          <a href="/images/large_leeboonstra_new.jpg">
            <picture>
              <source srcset="/images/small_leeboonstra_new.webp" type="image/webp">
              <img src="/images/small_leeboonstra_new.jpg" class="rounded mx-auto d-block" alt="Lee Boonstra, AI Software Engineer and public keynote speaker.">
            </picture>
          </a>

          <!-- Elite Networking & Strategic Horizons Callout -->
          <div class="mt-4 networking-callout" style="font-size: 9pt; line-height: 1.5; border-left: 3px solid #e11d48; padding-left: 12px; color: #334155; text-align: left;">
            <p class="mb-2"><strong>🚀 Elite Networking & Strategic Horizons:</strong> Fully engaged in driving generative AI architecture at Google, but keeping a selective open channel for next-level frontier AI initiatives. If your Big Tech AI lab is actively looking for high-leverage AI engineers to bridge the gap between experimental R&D and market-disrupting agentic AI infrastructure, let’s talk.</p>
            <p class="mb-0 text-muted" style="font-size: 8pt; color: #64748b;"><strong>🛑 Note:</strong> Dedicated to my current scope; strictly not open to generic SWE, traditional cloud migration, legacy backend, non-staff, or non-remote roles.</p>
          </div>

          <!-- Dynamic Social / Portfolio Links -->
          <h3 class="card-title mt-4">Social Links</h3>
          <ul class="list-unstyled">
            <% var linkedIn = site.data.resume.basics.profiles.find(function(p) { return p.network === 'LinkedIn'; }); %>
            <% var github = site.data.resume.basics.profiles.find(function(p) { return p.network === 'GitHub'; }); %>
            <% if (github) { %>
              <li class="mb-2"><a href="<%= github.url %>" target="_blank" rel="noreferrer noopener" class="text-decoration-none">Github (<%= github.username %>)</a></li>
            <% } %>
            <li class="mb-2"><a href="<%= site.data.resume.basics.profiles.find(function(p){return p.network==='Amazon'}).url %>" target="_blank" rel="noreferrer noopener" class="text-decoration-none">Amazon Author Page</a></li>
            <% if (linkedIn) { %>
              <li class="mb-2"><a href="<%= linkedIn.url %>" target="_blank" rel="noreferrer noopener" class="text-decoration-none">LinkedIn (<%= linkedIn.username %>)</a></li>
            <% } %>
            <li class="mb-2"><a href="/speaking/" class="text-decoration-none">Past speaking events</a></li>
            <li class="mb-2"><a href="/videos/" class="text-decoration-none">Videos of me</a></li>
          </ul>

          <a href="/images/TechAI-Goolge-whitepaper_Prompt Engineering_v4.pdf" target="_blank">
            <picture>
                <img src="/images/small_prompting-paper.png" height="100%" style="display: block; width: auto;" class="border mb-3" alt="Download my Prompt Engineering whitepaper">
            </picture>
          </a> 
          <a href="/images/leeboonstra-specdriven-development.pdf" target="_blank">
            <picture>
                <img src="/images/small_vibecoding-paper.png" height="100%" style="display: block; width: auto;" class="border mb-3" alt="Download my Spec-Driven Development whitepaper">
            </picture>
          </a> 
        </div>
      </div>
    </div>
  </div>
</div>