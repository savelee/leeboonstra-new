<div class="reader-toggle-container">
  <a href="#" id="reader-toggle-btn" class="reader-toggle-btn" title="Toggle Reader Mode">
    <span class="reader-toggle-icon">📖</span>
    <span class="reader-toggle-text">Reader View</span>
  </a>
</div>

<script>
  (function() {
    document.addEventListener('DOMContentLoaded', function() {
      var toggleBtn = document.getElementById('reader-toggle-btn');
      var container = toggleBtn ? toggleBtn.parentElement : null;
      if (!toggleBtn || !container) return;

      // Make button container active now that JS script works
      container.style.display = 'inline-flex';

      function updateButtonState(isReader) {
        var icon = toggleBtn.querySelector('.reader-toggle-icon');
        var text = toggleBtn.querySelector('.reader-toggle-text');
        if (isReader) {
          if (icon) icon.textContent = '🖥️';
          if (text) text.textContent = 'Standard View';
          toggleBtn.title = 'Switch to Standard View';
        } else {
          if (icon) icon.textContent = '📖';
          if (text) text.textContent = 'Reader View';
          toggleBtn.title = 'Switch to Reader View';
        }
      }

      // Read state initially
      var isCurrentReader = document.documentElement.classList.contains('force-ereader');
      updateButtonState(isCurrentReader);

      toggleBtn.addEventListener('click', function(e) {
        e.preventDefault();
        var active = document.documentElement.classList.toggle('force-ereader');
        
        // Save choice in local storage
        if (active) {
          localStorage.setItem('reader-mode', 'true');
        } else {
          localStorage.setItem('reader-mode', 'false');
        }

        // Seamless parameter replacement on current navigation URL
        var url = new URL(window.location.href);
        if (active) {
          url.searchParams.set('reader', '1');
        } else {
          url.searchParams.delete('reader');
          url.searchParams.delete('ereader');
        }
        window.history.replaceState({}, '', url.toString());

        // Refresh button label state
        updateButtonState(active);
      });
    });
  })();
</script>
