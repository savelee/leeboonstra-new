        {
          "@context": "https://schema.org",
          "@type": "AboutPage",
          "headline": "<%- page.title %>",
          "description": "<%- page.description %>",
          "mainEntity": {
            "@type": "Person",
            "name": "Lee Boonstra",
            "@id": "https://www.leeboonstra.dev/#person"
          }
        }
        </script>
          <script type="application/ld+json">
