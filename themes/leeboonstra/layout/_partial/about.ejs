<div class="container about<% if (page.layout === 'about' || page.layout === 'bio') { %> Biography<% } %>">
    <!-- Print-Only Resume Header -->
    <% if (page.layout === 'about' || page.layout === 'bio') { %>
    <div class="print-only-header">
      <div class="print-header-row">
        <div class="print-header-left">
          <h1 class="print-name"><%= site.data.resume.basics.name %></h1>
          <div class="print-title"><%= site.data.resume.basics.label %></div>
          <div class="print-pronouns">
            Pronouns: <%= site.data.resume.basics.pronouns %> &nbsp;|&nbsp; Born: 16 June 1983, Apeldoorn, Netherlands
            <br>
            Current Location: <%= site.data.resume.basics.location.city %>, <%= site.data.resume.basics.location.country %>
          </div>
        </div>
        <div class="print-header-right text-right">
          <div class="contact-item"><strong>Web:</strong> <%= site.data.resume.basics.url.replace(/^https?:\/\/(www\.)?/, '') %></div>
          <% var linkedIn = site.data.resume.basics.profiles.find(function(p) { return p.network === 'LinkedIn'; }); %>
          <% var github = site.data.resume.basics.profiles.find(function(p) { return p.network === 'GitHub'; }); %>
          <% if (linkedIn) { %>
            <div class="contact-item"><strong>LinkedIn:</strong> <%= linkedIn.url.replace(/^https?:\/\/(www\.)?/, '') %></div>
          <% } %>
          <% if (github) { %>
            <div class="contact-item"><strong>GitHub:</strong> <%= github.url.replace(/^https?:\/\/(www\.)?/, '') %></div>
          <% } %>
          <div class="contact-item"><strong>Email:</strong> <%= site.data.resume.basics.email.replace('@', '[at]') %></div>
        </div>
      </div>
    </div>
    <% } %>

    <div class="row justify-content-md-center">
      <div class="col-8 blogcontent">
  
        <h1><%-page.title %></h1>
  
        <h2 class="hidden"><%-page.subtitle %></h2>

        <%- page.content %>

        <!-- Rich JSON-LD Microdata: Connects profile targets directly to recruitment crawlers -->
        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "ProfilePage",
          "mainEntity": {
            "@type": "Person",
            "name": "<%= site.data.resume.basics.name %>",
            "jobTitle": "AI Software Engineer & Tech Lead",
            "worksFor": {
              "@type": "Organization",
              "name": "Google"
            },
            "knowsAbout": [
              <% 
                var allKws = []; 
                site.data.resume.skills.forEach(function(group) { 
                  group.keywords.forEach(function(kw) { 
                    allKws.push(kw); 
                  }); 
                }); 
              %>
              <%- allKws.map(function(k) { return `"${k}"`; }).join(', ') %>
            ]
          }
        }
        </script>
   
      </div>
      <div class="col-4 photocol">
        <div class="card shadow sidebar">
          <div class="card-body">
            <h3 class="card-title">Photo's</h3>
            <a href="/images/large_leeboonstra_new.jpg">
              <picture>
                <source srcset="/images/small_leeboonstra_new.webp 200w">
                <img src="/images/small_leeboonstra_new.jpg" class="rounded mx-auto d-block" alt="Lee Boonstra, Developer Relations Engineer and public speaker." />
              </picture>
            </a>

            <!-- Print Resume CTA button -->
            <% if (page.layout === 'about' || page.layout === 'bio') { %>
            <button onclick="window.print()" class="btn btn-block btn-outline-danger mt-3 print-resume-btn">
               <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-printer mr-2" viewBox="0 0 16 16" style="vertical-align: text-bottom; display: inline-block;">
                 <path d="M2.5 8a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1"/>
                 <path d="M5 1a2 2 0 0 0-2 2v2H2a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h1v3a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-3h1a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-1V3a2 2 0 0 0-2-2zM4 3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2H4zm1 5a2.5 2.5 0 0 0-2.5 2.5v3h7v-3A2.5 2.5 0 0 0 7 8zm0 5.5v-3a1.5 1.5 0 0 1 1.5-1.5h3a1.5 1.5 0 0 1 1.5 1.5v3z"/>
               </svg>
               Print My Resume
            </button>
            <% } %>

            <!-- Dynamic Social / Portfolio Links -->
            <h3 class="card-title mt-4">Social Links</h3>
            <ul class="list-unstyled">
              <% if (github) { %>
                <li class="mb-2"><a href="<%= github.url %>" target="_blank" rel="noreferrer noopener" class="text-decoration-none">Github (<%= github.username %>)</a></li>
              <% } %>
              <li class="mb-2"><a href="<%= site.data.resume.basics.profiles.find(function(p){return p.network==='Amazon'}).url %>" target="_blank" rel="noreferrer noopener" class="text-decoration-none">Amazon Author Page</a></li>
              <% if (linkedIn) { %>
                <li class="mb-2"><a href="<%= linkedIn.url %>" target="_blank" rel="noreferrer noopener" class="text-decoration-none">LinkedIn (<%= linkedIn.username %>)</a></li>
              <% } %>
              <li class="mb-2"><a href="/speaker" target="_blank" rel="noreferrer noopener" class="text-decoration-none">Past speaking events</a></li>
              <li class="mb-2"><a href="/videos" target="_blank" rel="noreferrer noopener" class="text-decoration-none">Videos of me</a></li>
            </ul>

            <a href="/images/TechAI-Goolge-whitepaper_Prompt Engineering_v4.pdf" target="_blank">
              <picture>
                  <img src="/images/small_prompting-paper.png" width="76" height="100" style="display: block;" class="border mb-3" alt="Download my Prompt Engineering whitepaper">
              </picture>
            </a> 
          </div>
        </div>
      </div>
    </div>
  
    <!-- Dynamic Bento Grid Resume Section -->
    <% if (page.layout === 'about' || page.layout === 'bio') { %>
    <div class="resume">
      <div class="row justify-content-md-center mt-4">
        <div class="col-14">
          <div class="card h-100">
            <div class="card-body">
              <h2 class="card-title text-3xl font-bold section-title mb-4 resume-main-title">My Resume</h2>
              <% if (linkedIn) { %>
                <div class="mb-4 linkedin-connect-prompt">
                  <a href="<%= linkedIn.url %>" target="_blank" class="text-blue-600">
                    <span class="font-medium">Let's connect on LinkedIn</span>
                  </a>
                </div>
              <% } %>

              <!-- Dynamic Helper formatting dates to standard screen display templates -->
              <% 
                function formatYear(dateStr) {
                  if (!dateStr) return 'present';
                  return dateStr.split('-')[0];
                }
              %>

              <!-- Experience Bento Grid -->
              <div class="resume-section resume-experience mb-6">
                  <h2 class="text-xl font-semibold mb-4">Professional Experience</h2>
                  <p><%= site.data.resume.basics.experienceIntro %></p>
                  <div class="row">
                    <% site.data.resume.work.forEach(function(job) { %>
                      <div class="col-md-6 mb-4">
                          <div class="experience-chip">
                              <span class="chip-date"><%= job.name %>, <%= formatYear(job.startDate) %> – <%= formatYear(job.endDate) %></span>
                              <h4 class="chip-title"><%= job.position %></h4>
                              <ul class="chip-list">
                                  <% job.highlights.forEach(function(bullet) { %>
                                    <li><%= bullet %></li>
                                  <% }) %>
                              </ul>
                          </div>
                      </div>
                    <% }) %>
                  </div>
              </div>

              <!-- Patents & Inventions Bento Grid -->
              <div class="resume-section resume-patents mb-6">
                  <h2 class="text-xl font-semibold mb-4">Patents & Inventions</h2>
                  <div class="row">
                    <% 
                      var patents = site.data.resume.publications.filter(function(p) { return p.type === 'patent'; }); 
                      function getPatentStatus(pat) {
                        var year = pat.releaseDate.split('-')[0];
                        if (pat.name.includes('Invention Disclosure')) return 'Filed (Invention Disclosure) ' + year;
                        if (pat.name.includes('US20250078820A1')) return 'Published ' + year;
                        return 'Filed ' + year;
                      }
                    %>
                    <% patents.forEach(function(pat) { %>
                      <div class="col-md-<%= pat.name.includes('US20250078820A1') ? '12' : '6' %> mb-4">
                          <div class="experience-chip">
                              <span class="chip-date"><%= getPatentStatus(pat) %></span>
                              <h4 class="chip-title">
                                  <% if (pat.url) { %>
                                    <a href="<%= pat.url %>" target="_blank" rel="noopener" style="color: inherit; text-decoration: underline;">
                                        <%= pat.name %>
                                    </a>
                                  <% } else { %>
                                    <%= pat.name %>
                                  <% } %>
                              </h4>
                              <p class="chip-text mt-2"><%= pat.summary %></p>
                          </div>
                      </div>
                    <% }) %>
                  </div>
              </div>

              <!-- Publications & Books Bento Grid -->
              <div class="resume-section resume-publications mb-6">
                  <h2 class="text-xl font-semibold mb-4">Publications & Books</h2>
                  <div class="row">
                    <% 
                      var publications = site.data.resume.publications.filter(function(p) { return p.type !== 'patent'; }); 
                    %>
                    <% publications.forEach(function(pub) { %>
                      <div class="col-md-<%= pub.releaseDate.startsWith('2025') ? '12' : '6' %> mb-4">
                          <div class="experience-chip">
                              <span class="chip-date"><%= pub.releaseDate.split('-')[0] %></span>
                              <h4 class="chip-title"><%= pub.name %></h4>
                              <p class="chip-text mt-2">
                                  <%= pub.summary %>
                                  <% if (pub.url) { %>
                                    <br>
                                    <a href="<%= pub.url %>" target="_blank" rel="noopener" style="color: inherit; text-decoration: underline; font-weight: 600;">
                                        View details
                                    </a>
                                  <% } %>
                              </p>
                          </div>
                      </div>
                    <% }) %>
                  </div>
              </div>

              <!-- Education Bento Grid -->
              <div class="resume-section resume-education mb-6">
                  <h2 class="text-xl font-semibold mb-4">Education</h2>
                  <% site.data.resume.education.forEach(function(edu) { %>
                    <div class="education-chip">
                        <span class="chip-date"><%= edu.startDate.split('-')[0] %>-<%= edu.endDate.split('-')[0] %></span>
                        <h4 class="chip-title"><%= edu.institution %></h4>
                        <p class="chip-text"><%= edu.studyType %> in <%= edu.area %></p>
                    </div>
                  <% }) %>
              </div>

              <!-- Dynamic Technical Skills Bento Grid -->
              <div class="resume-section resume-skills mb-6">
                  <h2 class="text-xl font-semibold mb-4">Technical Skills</h2>
                  <div class="row">
                    <% site.data.resume.skills.forEach(function(skillGroup) { %>
                      <div class="col-md-4 mb-4">
                          <div class="skill-chip">
                              <h4 class="chip-title"><%= skillGroup.name %></h4>
                              <div class="skill-tags">
                                <% skillGroup.keywords.forEach(function(kw) { %>
                                  <span class="skill-tag"><%= kw %></span>
                                <% }) %>
                              </div>
                          </div>
                      </div>
                    <% }) %>
                  </div>
              </div>

              <!-- Spoken Languages Bento Grid -->
              <div class="resume-section resume-languages mb-6">
                  <h2 class="text-xl font-semibold mb-4">Spoken Languages</h2>
                  <div class="languages-chip">
                    <% site.data.resume.languages.forEach(function(lang) { %>
                      <div class="language-item">
                          <span class="language-name"><%= lang.language %></span>
                          <span class="language-level"><%= lang.fluency %></span>
                      </div>
                    <% }) %>
                  </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>
    
    <% } %>
</div>
